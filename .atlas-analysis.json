  "keyFeatures": [
    "Email/password and Google OAuth authentication with Better Auth",
    "PostgreSQL database with Drizzle ORM",
    "JWT token generation with JWKS endpoint for backend verification",
    "API proxy with automatic JWT injection",
    "Pre-configured database schema for auth tables",
    "Dev Container support with PostgreSQL",
    "TypeScript API clients (fetch and axios) with automatic token refresh",
    "shadcn/ui components with dark mode support"
  ],
  "publicApiSurface": [
    "authClient.signIn.email()",
    "authClient.signIn.social()",
    "authClient.signUp.email()",
    "authClient.signOut()",
    "authClient.useSession()",
    "authClient.token()",
    "apiClient.request()",
    "apiClient.verifyAuth()",
    "auth.api.getToken()",
    "/api/auth/jwks",
    "/api/auth/callback/google",
    "/api/[...path] (proxy route)"
  ]
}
